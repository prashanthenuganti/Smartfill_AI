{
  "manifest_version": 3,
  "name": "SmartFill AI",
  "version": "2.0.0",
  "description": "Upload documents \u2192 extract data \u2192 fill any government form automatically.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartFill AI"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://web-production-a52e0.up.railway.app/*",
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
